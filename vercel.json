{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/tonconnect-manifest.json",
      "destination": "/api/tonconnect-manifest"
    },
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/run",
      "schedule": "*/15 * * * *"
    }
  ]
}
